# URL of the deployed frontend - used to build shareable invite links.
FRONTEND_URL=http://localhost:3000

# Comma-separated list of origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# The database starts empty; users self-register via OTP-verified signup.
# Set to true to also seed a few sample meetings (hosted by the first user).
SEED_SAMPLE_DATA=false

# --- Auth ---
# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=168

# --- Email / OTP (signup verification codes) ---
# Sender defaults to vipinkarthic17112005@gmail.com. To ACTUALLY send emails,
# set SMTP_PASS to a Gmail *App Password* (Google Account > Security >
# 2-Step Verification > App Passwords - a 16-char code, NOT your login password).
# Leave SMTP_PASS blank to run in dev mode (the OTP is shown in the UI + logged).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=vipinkarthic17112005@gmail.com
SMTP_PASS=
SMTP_FROM_NAME=Zoom Clone
OTP_TTL_MINUTES=10
# Seconds to wait on the SMTP socket before giving up.
SMTP_TIMEOUT=15
